│   │   └── analysisRoutes.js    # Definición de rutas /api/analyses
│   ├── services/
│   │   ├── cerebrasService.js   # Llamada a Cerebras y normalización
│   │   ├── databaseService.js   # Operaciones CRUD y caché
│   │   ├── newsService.js       # Consulta a GNews
│   │   └── textExtractor.js     # Extracción de texto desde URL
